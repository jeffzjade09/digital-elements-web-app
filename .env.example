# ---- Server ----
PORT=4000
# Public URL where the app is reachable (used for the Google OAuth callback and
# to decide whether cookies are HTTPS-only). No trailing slash.
PUBLIC_URL=http://localhost:4000

# ---- Database: Supabase (Postgres) ----
# Supabase Dashboard > Project Settings > Database > Connection string (URI).
# Use the "Connection pooling" (port 6543) string for a deployed app.
DATABASE_URL=

# ---- Login / sessions ----
# Long random string that signs session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
# Comma-separated emails that are granted Admin automatically on startup, so the
# first person can sign in and then add everyone else from the Users screen.
ADMIN_EMAILS=you@yourcompany.com

# ---- Google SSO ----
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID (Web).
# Authorized redirect URI must be:  {PUBLIC_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Google PageSpeed Insights ----
# Optional but strongly recommended. Without a key you share a tiny anonymous
# quota and will be rate-limited quickly. Get a free key:
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
# mobile | desktop
PAGESPEED_STRATEGY=mobile

# ---- ClickUp (optional: shows task counts per site) ----
# Personal API token from ClickUp > Settings > Apps (starts with pk_).
CLICKUP_API_TOKEN=
# Workspace/Team ID. Leave blank to auto-detect your first workspace.
CLICKUP_TEAM_ID=

# ---- Zoho Projects (optional: task counts per site; works alongside ClickUp) ----
# Create a "Self Client" at https://api-console.zoho.com, then generate a grant
# code with scope:
#   ZohoProjects.portals.READ,ZohoProjects.projects.READ,ZohoProjects.tasks.READ,ZohoProjects.users.READ
# and exchange it for a refresh token:
#   curl -X POST "https://accounts.zoho.com/oauth/v2/token" \
#     -d "grant_type=authorization_code&client_id=...&client_secret=...&code=GRANT_CODE"
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Portal ID. Leave blank to auto-detect your first portal.
ZOHO_PORTAL_ID=
# Data center TLD from your Zoho login URL: com (US), eu, in, com.au, jp
ZOHO_DC=com

# ---- Scheduled checks ----
# Cron expression for background checks. Default: every 6 hours.
# ---- Scheduling ----
# How often the dashboard checks run (seconds). The cheap checks refresh this
# often; PageSpeed is throttled separately below so frequent sweeps stay light.
SWEEP_INTERVAL_SECONDS=60
# Minimum seconds between PageSpeed runs per site (it's slow and rate-limited).
PAGESPEED_MIN_INTERVAL_SECONDS=120
# Run a full check once on startup (true/false)
CHECK_ON_START=true

# ---- Thresholds ----
# PageSpeed performance score (0-100): below WARN = amber, below FAIL = red
PAGESPEED_WARN=90
PAGESPEED_FAIL=50
# SSL certificate: warn when fewer than this many days remain
SSL_WARN_DAYS=14

# ---- Page-view analytics (optional; see analytics-worker/) ----
# URL of the deployed "de-analytics" Cloudflare Worker, no trailing slash,
# e.g. https://de-analytics.<your-subdomain>.workers.dev
# Sites' helper plugins pick this up automatically via license validation.
ANALYTICS_URL=
# Must match the STATS_KEY secret set on the Worker (wrangler secret put STATS_KEY).
# Generate one with: openssl rand -hex 24
ANALYTICS_STATS_KEY=

# ---- Alerts: Slack (optional) ----
# Incoming webhook URL. Leave blank to disable.
SLACK_WEBHOOK_URL=

# ---- Alerts: Email (optional) ----
# Leave SMTP_HOST blank to disable email alerts.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
